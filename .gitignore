# ==============================
# macOS system files
# ==============================
.DS_Store
._*

# ==============================
# Python bytecode and test cache
# ==============================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ==============================
# Python virtual environments
# ==============================
.venv/
venv/
env/

# ==============================
# IDE and editor metadata
# ==============================
.vscode/
.idea/
*.swp
*.swo

# ==============================
# Logs and temporary files
# ==============================
*.log
*.tmp
*.temp

# ==============================
# MovieLens raw downloaded archives
#
# Keep download scripts and directory placeholders in git,
# but do not commit large official dataset archives.
# ==============================
dataset-movie_lens/raw/*
!dataset-movie_lens/raw/.gitkeep
!dataset-movie_lens/raw/*.md5
!dataset-movie_lens/raw/README.md
!dataset-movie_lens/raw/README.zh.md
dataset-movie_lens/raw/ml-*/

# ==============================
# MovieLens processed experiment data
#
# Processed files are generated locally by experiments.
# Keep only the directory placeholder in git.
# ==============================
dataset-movie_lens/processed/*
!dataset-movie_lens/processed/.gitkeep
!dataset-movie_lens/processed/README.md
!dataset-movie_lens/processed/README.zh.md

# ==============================
# Local notebooks and generated reports
# ==============================
.ipynb_checkpoints/
reports/generated/

# ==============================
# Model checkpoints
#
# Experiments may save one best checkpoint and a few sparse intermediate
# checkpoints locally. These files can become large and should not enter git.
# ==============================
**/checkpoints/
*.pt
*.pth

# ==============================
# MkDocs build output
#
# The site directory is generated by mkdocs build.
# Keep source Markdown and configuration in git.
# ==============================
docs-site/site/
